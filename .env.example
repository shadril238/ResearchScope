# ResearchScope environment variables
# Copy this file to .env and fill in values as needed.
# None of these are required for the MVP — arXiv and ACL Anthology are public.

# Optional: Semantic Scholar API key for citation data
# SEMANTIC_SCHOLAR_KEY=your_key_here

# Optional: OpenAI-compatible key for LLM-powered enrichment (future)
# OPENAI_API_KEY=your_key_here

# Optional: Anthropic API key (future)
# ANTHROPIC_API_KEY=your_key_here
